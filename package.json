{
  "name": "notepack-obsidian",
  "version": "1.3.5",
  "description": "NotePack plugin for Obsidian - Todo collation with team management",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage",
    "preversion": "node scripts/preversion.js && npm test",
    "version": "node scripts/version.js && git add manifest.json",
    "postversion": "node scripts/postversion.js"
  },
  "keywords": [
    "obsidian",
    "notepack",
    "todos",
    "team"
  ],
  "author": "Dave Shepard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kynatro/notepack-obsidian.git"
  },
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.27.4",
    "jest": "^30.3.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  }
}
